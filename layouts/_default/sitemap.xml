{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range site.Pages }}
  {{- if not (in (slice "taxonomy" "term") .Kind) }}
  {{- $p := . }}
  <url>
    <loc>{{ $p.Permalink }}</loc>
    {{- if not $p.Lastmod.IsZero }}
    <lastmod>{{ $p.Lastmod.Format "2006-01-02" }}</lastmod>
    {{- end }}
    <priority>{{ if eq $p.Kind "home" }}1.0{{ else if eq $p.Section "expertise" }}0.9{{ else if eq $p.Section "insights" }}0.8{{ else if or (eq $p.Section "patients") (eq $p.Section "about") }}0.7{{ else if eq $p.Section "contact" }}0.6{{ else }}0.5{{ end }}</priority>
    {{- if gt (len site.Sites) 1 }}
    {{- $enPage := index (where $p.AllTranslations "Lang" "en") 0 }}
    {{- if $enPage }}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ $enPage.Permalink }}"/>
    {{- end }}
    {{- range $p.AllTranslations }}
    <xhtml:link rel="alternate" hreflang="{{ .Lang }}" href="{{ .Permalink }}"/>
    {{- end }}
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
</urlset>
